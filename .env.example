# API keys (copy this file to .env and fill in your keys)
#   cp .env.example .env
# .env is gitignored. Location: repo root (same directory as run.py).
#
# Get keys: Alpha Vantage https://www.alphavantage.co/support/#api-key
#          Marketaux https://www.marketaux.com/register

# Required for price ingest (python run.py ingest)
ALPHAVANTAGE_API_KEY=

# Required for news ingest when use_news: true in configs/default.yaml
MARKETAUX_API_KEY=

# Optional: serve stage
# MODEL_RUN_ID=              # specific model run (default: latest under models/)
# SERVE_MODELS_PATH=         # override models dir (e.g. for tests)
# SERVE_PROCESSED_PATH=     # override processed data dir (e.g. for tests)
# SERVE_DRY_RUN=1            # set to skip starting uvicorn (used in tests)

# Testing: pytest loads this .env from repo root (tests/conftest.py) when present.
# Unit tests mock API keys; a local .env is only needed if you run tests that call real APIs.
